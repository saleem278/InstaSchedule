# ---- Server ----
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173

# ---- Database ----
MONGO_URI=mongodb://localhost:27017/instapost

# ---- Auth (JWT) ----
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# ---- Google OAuth (optional — Google login is hidden if unset) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# ---- Redis / BullMQ (optional — falls back to synchronous image generation if unset) ----
REDIS_URL=

# ---- Cloudinary (optional — falls back to local disk storage if unset) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- AI Providers ----
# Text generation has NO offline fallback — a valid key for the selected
# TEXT_PROVIDER is required to generate content.
# TEXT_PROVIDER=openai requires OPENAI_API_KEY (paid, no free tier).
# TEXT_PROVIDER=gemini requires GEMINI_API_KEY (has a genuinely free tier —
# get one at https://aistudio.google.com/app/apikey).
TEXT_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash

# Image generation defaults to Pollinations, which needs no API key.
IMAGE_PROVIDER=pollinations
